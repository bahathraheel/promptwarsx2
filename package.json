{
  "name": "elite-election",
  "version": "1.0.0",
  "description": "ELITE ELECTION — Immersive 3D AI Election Assistant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --verbose --coverage --forceExit",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:security": "jest tests/security --verbose",
    "lint": "eslint src/ server.js",
    "validate": "node validate.js"
  },
  "keywords": ["election", "3d", "ai", "assistant", "threejs"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "@google/generative-ai": "^0.21.0",
    "@google-cloud/logging": "^11.2.0",
    "@google-cloud/translate": "^8.5.0",
    "@google-cloud/text-to-speech": "^5.5.0",
    "@google-cloud/language": "^6.5.0",
    "@google-cloud/recaptcha-enterprise": "^5.3.0",
    "@google-cloud/tasks": "^5.5.0",
    "@google-cloud/secret-manager": "^6.1.0",
    "@google-cloud/firestore": "^7.10.0",
    "@google-cloud/storage": "^7.13.0",
    "@google-cloud/monitoring": "^4.1.0",
    "firebase-admin": "^12.6.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./tests/setup.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "server.js",
      "!**/node_modules/**"
    ]
  }
}
